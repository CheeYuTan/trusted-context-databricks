  "serialized_dashboard": {
    "datasets": [
      {
        "name": "summary",
        "displayName": "KPI Summary",
        "queryLines": [
          "SELECT MEASURE(actual_revenue) AS actual_revenue, MEASURE(ebitda) AS ebitda, MEASURE(ebitda_margin_pct) AS ebitda_margin_pct, MEASURE(revenue_variance_pct) AS revenue_variance_pct FROM lakemeter_catalog.metric_views_lod_demo.finance_metric_view WHERE fiscal_year = 2025"
        ]
      },
      {
        "name": "executive_overview",
        "displayName": "Executive Overview",
        "queryLines": [
          "SELECT fiscal_month, region, MEASURE(actual_revenue) AS actual_revenue, MEASURE(budget_revenue) AS budget_revenue, MEASURE(revenue_variance_pct) AS revenue_variance_pct, MEASURE(ebitda) AS ebitda, MEASURE(ebitda_margin_pct) AS ebitda_margin_pct FROM lakemeter_catalog.metric_views_lod_demo.finance_metric_view WHERE fiscal_year = 2025 GROUP BY ALL ORDER BY fiscal_month, region"
        ]
      },
      {
        "name": "lod_drilldown",
        "displayName": "LOD Drilldown",
        "queryLines": [
          "SELECT region, entity_name, product_family, MEASURE(actual_revenue) AS actual_revenue, MEASURE(pct_of_global_revenue_fixed_lod) AS pct_of_global_revenue, MEASURE(pct_of_region_revenue) AS pct_of_region_revenue, MEASURE(pct_of_entity_product_visible_total) AS pct_of_visible_total FROM lakemeter_catalog.metric_views_lod_demo.finance_metric_view WHERE fiscal_year = 2025 AND account_category = 'Revenue' GROUP BY ALL ORDER BY region, entity_name, product_family"
        ]
      },
      {
        "name": "window_semantics",
        "displayName": "Window Semantics",
        "queryLines": [
          "SELECT fiscal_month, region, MEASURE(current_month_revenue) AS current_month_revenue, MEASURE(ytd_revenue) AS ytd_revenue, MEASURE(rolling_12_month_revenue) AS rolling_12_month_revenue, MEASURE(prior_year_revenue) AS prior_year_revenue, MEASURE(yoy_revenue_growth_pct) AS yoy_revenue_growth_pct FROM lakemeter_catalog.metric_views_lod_demo.finance_metric_view WHERE fiscal_month >= DATE'2025-01-01' GROUP BY ALL ORDER BY fiscal_month, region"
        ]
      },
      {
        "name": "balances",
        "displayName": "Semiadditive Balances",
        "queryLines": [
          "SELECT fiscal_quarter, entity_name, account_category, MEASURE(month_end_balance) AS month_end_balance FROM lakemeter_catalog.metric_views_lod_demo.finance_metric_view WHERE statement_section = 'Balance Sheet' AND fiscal_year = 2025 GROUP BY ALL ORDER BY fiscal_quarter, entity_name, account_category"
        ]
      },
      {
        "name": "exec_composability",
        "displayName": "Cross Metric View Composability",
        "queryLines": [
          "SELECT fiscal_month, region, MEASURE(revenue_per_transaction) AS revenue_per_transaction, MEASURE(executive_score) AS executive_score FROM lakemeter_catalog.metric_views_lod_demo.finance_exec_metric_view WHERE fiscal_year = 2025 GROUP BY ALL ORDER BY fiscal_month, region"
        ]
      }
    ],
